// Firestore Security Rules for SmartERP
// Single-user mode: Only authenticated user can read/write their data

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getCurrentUserId() {
      return request.auth.uid;
    }
    
    // Validate product data structure
    function isValidProduct() {
      return request.resource.data.keys().hasAll(['name', 'price', 'quantity', 'sku']) &&
             request.resource.data.name is string &&
             request.resource.data.name.size() >= 1 &&
             request.resource.data.price is number &&
             request.resource.data.price >= 0 &&
             request.resource.data.quantity is number &&
             request.resource.data.quantity >= 0;
    }
    
    // Validate invoice data structure
    function isValidInvoice() {
      return request.resource.data.keys().hasAll(['invoiceNumber', 'customerName', 'items', 'totalAmount']) &&
             request.resource.data.invoiceNumber is string &&
             request.resource.data.customerName is string &&
             request.resource.data.items is list &&
             request.resource.data.items.size() > 0 &&
             request.resource.data.totalAmount is number &&
             request.resource.data.totalAmount > 0;
    }
    
    // Settings collection - authenticated users can read/write
    match /settings/{document=**} {
      allow read, write: if isAuthenticated();
    }
    
    // Products collection
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidProduct();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
      
      // Index requirement: name, category, active
    }
    
    // Invoices collection  
    match /invoices/{invoiceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidInvoice();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
      
      // Index requirement: status, invoiceDate
      // Index requirement: customerId, invoiceDate
    }
    
    // Sales orders collection
    match /sales/{saleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // Payroll collection
    match /payroll/{payrollId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
      
      // Index requirement: month
    }
    
    // Expenses collection
    match /expenses/{expenseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
      
      // Index requirement: status, expenseDate
      // Index requirement: category, expenseDate
    }
    
    // Reports collection
    match /reports/{reportId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // Users collection (profile data)
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
      }
      match /purchases/{purchaseId} {
        allow read, write: if isOwner(userId);
      }
      match /expenses/{expenseId} {
        allow read, write: if isOwner(userId);
      }
      match /employees/{employeeId} {
        allow read, write: if isOwner(userId);
      }
      match /salary_payments/{paymentId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
